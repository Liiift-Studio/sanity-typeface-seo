{
	"compilerOptions": {
		"target": "ES2017",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"declaration": true,
		"declarationDir": "dist",
		"outDir": "dist",
		"skipLibCheck": true,
		"jsx": "react-jsx"
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
